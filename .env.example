# Copy to .env, then fill in BASE_WS_URL.  docker-compose.yml reads this file.
#
# Each collector is pinned to a venue in docker-compose.yml via per-service
# environment vars (VENUE / CONNECTION_MODE / OUT_DIR); only the WS URLs (and the
# Base provider key) live here, plus optional shared tuning.

# === Base (primary) ===========================================================
#   docker-compose: VENUE=base  CONNECTION_MODE=eth_subscribe  OUT_DIR=/data/base
BASE_WS_URL=wss://your-provider.example/base/ws?key=YOUR_KEY
# TODO: possible to use ? wss://mainnet.flashblocks.base.org/ws

# === Unichain (optional) ======================================================
# Public sequencer flashblocks stream (brotli raw_ws) -- no API key needed.
#   docker-compose: VENUE=unichain  CONNECTION_MODE=raw_ws  OUT_DIR=/data/unichain
UNICHAIN_WS_URL=wss://mainnet-flashblocks.unichain.org/ws

# === Optional shared tuning (defaults shown; applied to both venues) ==========
#FLUSH_EVERY=50
#STALL_S=5
#HEARTBEAT_S=30
#BACKOFF_CAP_S=30
#DISK_MIN_FREE_MB=500
#LOG_LEVEL=INFO
#RETENTION_DAYS=
