# Unichain Flashblocks websocket stream (Rollup-Boost).
# Public mainnet default; swap for a paid Alchemy/QuickNode endpoint or the
# sepolia stream (wss://sepolia-flashblocks.unichain.org/ws).
WS_URL=wss://mainnet-flashblocks.unichain.org/ws

# Output directory INSIDE the container (bind-mounted to a WSL ext4 path).
OUT_DIR=/data

# fsync to disk every N records (and on every rotation / shutdown).
FLUSH_EVERY=50

# Warn if no frame arrives for this many seconds (stream stall).
STALL_S=5

# Heartbeat log interval (seconds).
HEARTBEAT_S=30

# Reconnect backoff cap (seconds).
BACKOFF_CAP_S=30

# Warn if free space on OUT_DIR drops below this many megabytes.
DISK_MIN_FREE_MB=500

# Logging verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Optional: delete *.jsonl.gz older than N days. Unset/empty = keep everything.
# RETENTION_DAYS=30
